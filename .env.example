# Database
DATABASE_URL=postgresql://username:password@localhost:5432/resume_matcher
# For development with SQLite
# DATABASE_URL=sqlite:///./resume_matcher.db

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIRECTORY=./data/vectordb

# API Configuration
API_V1_STR=/api/v1
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
APP_NAME=AI Resume Matcher
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
STREAMLIT_PORT=8501

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,docx,txt

# Data Storage
DATA_DIR=./data

# Embedding Model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Required: OpenAI API Key (or Groq/Gemini below)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Groq API Key (for faster processing)
GROQ_API_KEY=your_groq_api_key_here

GEMINI_API_KEY=your_gemini_api_key_here
